# bot
ADMIN_ID='[10001]'
PREFIX='["/", "!", ".", "#"]'

# connection
NC_PROTOCOL=ws
NC_HOST=127.0.0.1
NC_PORT=3001
NC_ACCESS_TOKEN=

# reconnection
NC_RECONNECTION_ENABLE=true
NC_RECONNECTION_ATTEMPTS=10
NC_RECONNECTION_DELAY=5000

# Minato
LOG_LEVEL=DEBUG
TIMEZONE=Asia/Shanghai
CONFIG_DIR=./config
LOG_DIR=./logs
DATA_DIR=./data
MODULES_DIR=./node_modules

DATABASE_URL="postgresql://postgres:password,@localhost:5432/ATRI"